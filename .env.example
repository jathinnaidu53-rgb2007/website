# ─── Sarada Homeo Clinic – Environment Variables Template ────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Google Analytics 4 ────────────────────────────────────────────────────────
# Get your Measurement ID from Google Analytics dashboard → Admin → Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Tag Manager ────────────────────────────────────────────────────────
# Optional. Only set if using GTM instead of / in addition to GA4.
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Formspree (Contact / Appointment form backend) ────────────────────────────
# Sign up at https://formspree.io, create a form, paste the ID here.
# NEXT_PUBLIC_FORMSPREE_ID=xxxxxxxxxxxx

# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://saradahomeoclinic.com

# ── Clinic Phone ──────────────────────────────────────────────────────────────
# Used for WhatsApp / call links across the site.
NEXT_PUBLIC_PHONE=919440955008
